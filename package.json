{
  "name": "multi-fb-manager",
  "version": "1.0.4",
  "description": "Multi‑FB Manager – desktop controller for Facebook multi‑account sessions",
  "productName": "Multi FB Manager",
  "main": "desktop/main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest",
    "dev": "concurrently \"npm:vite\" \"npm:start\"",
    "vite": "vite",
    "build": "vite build",
    "postinstall": "node scripts/postinstall.js",
    "package": "vite build && electron-builder",
    "package:win": "vite build && electron-builder --win",
    "package:mac": "vite build && electron-builder --mac",
    "package:linux": "vite build && electron-builder --linux",
    "release": "npm run package && electron-builder --publish always"
  },
  "keywords": [
    "facebook",
    "multi",
    "account",
    "manager"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "electron": "^40.1.0",
    "electron-builder": "^24.0.0",
    "electron-reloader": "^1.2.3",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.6",
    "rcedit": "^4.0.1",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.multi-fb.manager",
    "productName": "Multi FB Manager",
    "afterPack": "./scripts/embed-windows-icon.js",
    "publish": [
      {
        "provider": "github",
        "owner": "talal-ai",
        "repo": "fb-ids-messenger"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**",
      "control-plane/**",
      "contracts/**",
      "dist/**",
      "icon.png",
      "logo.ico",
      "package.json"
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "win": {
      "target": "nsis",
      "icon": "logo.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/postcss": "^4.1.18",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "electron-log": "^4.4.7",
    "electron-store": "^8.1.0",
    "electron-updater": "^5.3.0",
    "https-proxy-agent": "^7.0.6",
    "lucide-react": "^0.563.0",
    "node-telegram-bot-api": "^0.67.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socks-proxy-agent": "^8.0.5",
    "tailwind-merge": "^3.4.0"
  }
}
